<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_mrp_dashboard" model="ir.module.category">
        <field name="name">Dashboard Fabrication</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_mrp_dashboard_user" model="res.groups">
        <field name="name">Utilisateur Dashboard MRP</field>
        <field name="category_id" ref="module_category_mrp_dashboard"/>
    </record>

    <record id="group_mrp_dashboard_manager" model="res.groups">
        <field name="name">Responsable Dashboard MRP</field>
        <field name="category_id" ref="module_category_mrp_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('group_mrp_dashboard_user'))]"/>
    </record>

    <!-- Les responsables MRP héritent automatiquement du groupe manager dashboard -->
    <record id="mrp.group_mrp_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_mrp_dashboard_manager'))]"/>
    </record>
</odoo>
